#!/usr/bin/env bash
#
# gh-mine - Glance at your open GitHub pull requests across all your repos
#
# Usage: gh mine [--owner OWNER] [--limit N] [--table] [--no-color] [--no-links]
#   --owner OWNER  Filter by repository owner (default: all repos)
#   --limit N      Maximum number of PRs to fetch (default: 100)
#   --table        Print the table only (no interactive picker)
#   --no-color     Disable ANSI colors in output
#   --no-links     Disable terminal hyperlinks (OSC 8)
#   --version      Show version
#   --help, -h     Show this help

set -euo pipefail

VERSION="0.3.0"

# --- Defaults ---
OWNER=""
LIMIT=100
USE_COLOR=true
USE_LINKS=true
TABLE_ONLY=false

# --- Parse arguments ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --owner)
            OWNER="$2"
            shift 2
            ;;
        --limit)
            LIMIT="$2"
            shift 2
            ;;
        --no-color)
            USE_COLOR=false
            shift
            ;;
        --no-links)
            USE_LINKS=false
            shift
            ;;
        --table)
            TABLE_ONLY=true
            shift
            ;;
        --version)
            echo "gh-mine ${VERSION}"
            exit 0
            ;;
        --help|-h)
            sed -n '3,13p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            echo "Usage: gh mine [--owner OWNER] [--limit N] [--table] [--no-color] [--no-links]" >&2
            exit 1
            ;;
    esac
done

# --- Disable colors and links when not on a TTY ---
if [[ ! -t 1 ]]; then
    USE_COLOR=false
    USE_LINKS=false
fi

# --- Hyperlink helper (OSC 8) ---
# Use $'...' ANSI-C quoting to get real ESC bytes.
#
# tmux >= 3.4 with `terminal-features ":hyperlinks"` handles OSC 8 natively
# and forwards it to the host terminal. No DCS passthrough wrapping needed
# (and wrapping breaks the rendering). For older tmux without native OSC 8
# support, set MY_PRS_TMUX_PASSTHROUGH=1 to force DCS wrapping.
OSC8_START=$'\e]8;;'
OSC8_MID=$'\e\\'
OSC8_END=$'\e]8;;\e\\'

# tmux DCS passthrough wrappers (used only when explicitly forced)
TMUX_DCS_START=$'\ePtmux;'
TMUX_DCS_END=$'\e\\'
TMUX_OSC8_START=$'\e\e]8;;'
TMUX_OSC8_MID=$'\e\e\\'
TMUX_OSC8_END=$'\e\e]8;;\e\e\\'

hyperlink() {
    local url="$1" text="$2"
    if ! $USE_LINKS; then
        printf '%s' "$text"
        return
    fi
    if [[ -n "${TMUX:-}" ]] && [[ "${MY_PRS_TMUX_PASSTHROUGH:-0}" == "1" ]]; then
        # Legacy tmux without native OSC 8: wrap in DCS passthrough
        printf '%s' "${TMUX_DCS_START}${TMUX_OSC8_START}${url}${TMUX_OSC8_MID}${text}${TMUX_OSC8_END}${TMUX_DCS_END}"
    else
        # Modern tmux (>= 3.4 with hyperlinks feature) handles OSC 8 natively
        printf '%s' "${OSC8_START}${url}${OSC8_MID}${text}${OSC8_END}"
    fi
}

# --- Colors (real ESC bytes via ANSI-C quoting) ---
# Using $'...' rather than '\033...' so we don't depend on echo -e to interpret
# escapes — safer when mixed with OSC 8 hyperlinks which already contain real
# ESC bytes and a trailing backslash that echo -e would otherwise consume.
if $USE_COLOR; then
    # Catppuccin Mocha palette (256-color), inspired by gum/charm aesthetics
    RED=$'\e[38;5;210m'      # rosé/corail
    GREEN=$'\e[38;5;114m'    # vert sauge
    YELLOW=$'\e[38;5;222m'   # jaune miel
    BLUE=$'\e[38;5;111m'     # bleu ciel (sky)
    CYAN=$'\e[38;5;117m'     # cyan menthe
    MAUVE=$'\e[38;5;141m'    # mauve (header accent)
    PEACH=$'\e[38;5;216m'    # pêche (warm accent)
    GRAY=$'\e[38;5;245m'     # gris doux
    BOLD=$'\e[1m'
    DIM=$'\e[2m'
    RESET=$'\e[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAUVE='' PEACH='' GRAY='' BOLD='' DIM='' RESET=''
fi

# --- Sanity checks ---
for cmd in gh jq; do
    if ! command -v "$cmd" &>/dev/null; then
        printf '%s\n' "${RED}Error: required command '$cmd' not found${RESET}" >&2
        exit 1
    fi
done

# --- Verify gh authentication ---
if ! gh auth status &>/dev/null; then
    printf '%s\n' "${RED}Error: not authenticated with gh.${RESET} Run 'gh auth login' first." >&2
    exit 1
fi

# --- Cross-platform date helper ---
# GNU date (Linux) uses `-d`; BSD date (macOS) uses `-j -f <fmt>`.
# This helper accepts an ISO 8601 timestamp and an output format spec.
parse_date() {
    local iso="$1" fmt="$2"
    if date --version &>/dev/null; then
        # GNU date
        date -d "$iso" "+$fmt" 2>/dev/null
    else
        # BSD/macOS date — strip fractional seconds and timezone Z, normalize to UTC
        local clean="${iso%.*}"
        clean="${clean%Z}"
        date -j -u -f '%Y-%m-%dT%H:%M:%S' "$clean" "+$fmt" 2>/dev/null
    fi
}

# --- Build GraphQL search filter ---
# Use GraphQL search syntax to fetch PRs *and* CI status in one call.
# `gh search prs --owner X` historically accepted both users and orgs; in
# GraphQL search syntax, `org:X` is the closest equivalent and works for
# organizations (the typical case).
search_filter="is:open is:pr author:@me archived:false sort:updated-desc"
if [[ -n "$OWNER" ]]; then
    search_filter="${search_filter} org:${OWNER}"
fi

graphql_query=$(cat <<EOF
{
  search(query: "${search_filter}", type: ISSUE, first: ${LIMIT}) {
    nodes {
      ... on PullRequest {
        number
        title
        url
        isDraft
        updatedAt
        createdAt
        repository { nameWithOwner }
        labels(first: 20) {
          nodes { name }
        }
        commits(last: 1) {
          nodes {
            commit {
              statusCheckRollup { state }
            }
          }
        }
      }
    }
  }
}
EOF
)

# --- Fetch PRs (single GraphQL call: PR data + CI status) ---
json=$(gh api graphql -f query="$graphql_query" --jq '.data.search.nodes' 2>/dev/null) || {
    printf '%s\n' "${RED}Error: failed to fetch PRs from GitHub${RESET}" >&2
    exit 1
}

count=$(echo "$json" | jq 'length')

if [[ "$count" -eq 0 ]]; then
    if [[ -n "$OWNER" ]]; then
        printf '%s\n' "${GREEN}No open PRs found for owner '${OWNER}'.${RESET}"
    else
        printf '%s\n' "${GREEN}No open PRs found. Inbox zero! 🎉${RESET}"
    fi
    exit 0
fi

# --- Compute thresholds (epoch in seconds) ---
now_epoch=$(date +%s)
six_months_ago=$(( now_epoch - 6 * 30 * 86400 ))
one_month_ago=$(( now_epoch - 30 * 86400 ))

# --- Build rows: tab-separated fields ---
# Fields: repo, number, title, draft, updated, created, url, ci_state, labels
rows=$(echo "$json" | jq -r '.[] | [
    .repository.nameWithOwner,
    (.number|tostring),
    .title,
    (if .isDraft then "1" else "0" end),
    .updatedAt,
    .createdAt,
    .url,
    (.commits.nodes[0].commit.statusCheckRollup.state // "NONE"),
    ((.labels.nodes // []) | map(.name) | join(","))
] | @tsv')

# --- Determine repo column display ---
# When --owner is set, strip the owner prefix; otherwise keep the full path.
# Compute column widths
MAX_TITLE_CAP=70
max_repo=4    # "Repo"
max_num=1     # "#"
max_title=5   # "Title"

while IFS=$'\t' read -r repo num title _ _ _ _ _ _; do
    if [[ -n "$OWNER" ]]; then
        repo_display="${repo#*/}"
    else
        repo_display="$repo"
    fi
    [[ ${#repo_display} -gt $max_repo ]] && max_repo=${#repo_display}
    # Number column displays "#N" (or "#N*" for drafts)
    num_len=$(( ${#num} + 1 ))  # +1 for '#'
    [[ $num_len -gt $max_num ]] && max_num=$num_len
    title_len=${#title}
    [[ $title_len -gt $MAX_TITLE_CAP ]] && title_len=$MAX_TITLE_CAP
    [[ $title_len -gt $max_title ]] && max_title=$title_len
done <<< "$rows"

# Reserve one extra char in num column for the draft marker '*'
max_num=$(( max_num + 1 ))

# Date column is always 10 chars (YYYY-MM-DD)
max_date=10
# Age column max is "⚠ stale (>6mo)" = 14 visible chars
max_age=14
# CI column: 1 visible glyph (Nerd Font / emoji), padded to 2 cells
max_ci=2

# --- Decide rendering mode ---
# Picker mode (default): interactive gum filter, no static table.
# Table mode: print the full table only, no picker.
# Auto-fallback to table when stdout is not a TTY or gum is missing.
if $TABLE_ONLY || [[ ! -t 1 ]] || ! command -v gum &>/dev/null; then
    MODE="table"
else
    MODE="picker"
fi

# --- Build header strings (used either as printed table header or gum header) ---
plain_header=$(printf "%-${max_repo}s  %-${max_num}s  %-${max_title}s  %-${max_ci}s  %-${max_date}s  %-${max_age}s" \
    "Repo" "#" "Title" "CI" "Updated" "Age")
sep_len=$(( max_repo + max_num + max_title + max_ci + max_date + max_age + 10 ))
# Use U+2500 box-drawing char for a thinner, gum-style separator.
# tr would mangle multi-byte chars, so repeat with printf instead.
sep_str=$(printf '─%.0s' $(seq 1 $sep_len))

# Print the table header only in table mode
if [[ "$MODE" == "table" ]]; then
    printf '%s\n' "${BOLD}${MAUVE}${plain_header}${RESET}"
    printf '%s\n' "${DIM}${sep_str}${RESET}"
fi

# --- Build formatted rows (with and without OSC 8 hyperlinks) ---
# We collect the rows into arrays so we can either print the table OR feed
# them into the interactive picker (gum).
display_rows=()  # rows with OSC 8 hyperlinks (for terminal display)
picker_rows=()   # rows without OSC 8 (for gum filter — gum doesn't render OSC 8)
url_list=()      # parallel array of URLs

while IFS=$'\t' read -r repo num title draft updated created url ci_state labels; do
    # Repo display
    if [[ -n "$OWNER" ]]; then
        repo_display="${repo#*/}"
    else
        repo_display="$repo"
    fi

    # Truncate title if too long
    if [[ ${#title} -gt $MAX_TITLE_CAP ]]; then
        title="${title:0:$((MAX_TITLE_CAP-1))}…"
    fi

    # Parse updated date (cross-platform: GNU vs BSD date)
    updated_epoch=$(parse_date "$updated" '%s')
    [[ -z "$updated_epoch" ]] && updated_epoch="$now_epoch"
    updated_short=$(parse_date "$updated" '%Y-%m-%d')
    [[ -z "$updated_short" ]] && updated_short="????-??-??"

    # Age marker (visible text + color)
    if (( updated_epoch < six_months_ago )); then
        age_text="⚠ stale (>6mo)"
        age_color="$RED"
    elif (( updated_epoch < one_month_ago )); then
        age_text="old (>1mo)"
        age_color="$YELLOW"
    else
        age_text="fresh"
        age_color="$GREEN"
    fi

    # Number with optional draft marker
    if [[ "$draft" == "1" ]]; then
        num_text="#${num}*"
        num_color="$GRAY"
    else
        num_text="#${num}"
        num_color="$BLUE"
    fi

    # Title color (red if PR has 'security' label)
    if [[ ",${labels}," == *,security,* ]]; then
        title_color="$RED"
    else
        title_color="$RESET"
    fi

    # CI status glyph + color (Nerd Font)
    # nf-oct-check, nf-oct-x, nf-oct-clock, nf-oct-dash
    case "$ci_state" in
        SUCCESS)
            ci_text=$'\uf00c'
            ci_color="$GREEN"
            ;;
        FAILURE|ERROR)
            ci_text=$'\uf00d'
            ci_color="$RED"
            ;;
        PENDING|EXPECTED)
            ci_text=$'\uf017'
            ci_color="$YELLOW"
            ;;
        *)
            ci_text=$'\uf068'
            ci_color="$GRAY"
            ;;
    esac

    # Pre-pad each field to its column width using plain text (no ANSI codes),
    # then wrap with colors and hyperlinks. This avoids printf counting escape
    # sequences in widths.
    repo_padded=$(printf "%-${max_repo}s" "$repo_display")
    num_padded=$(printf "%-${max_num}s" "$num_text")
    title_padded=$(printf "%-${max_title}s" "$title")
    # CI glyph is a single Nerd Font codepoint (1 terminal cell) but bash
    # printf pads by byte count, not cell width — so we pad manually to
    # keep the following columns aligned.
    ci_padded="${ci_text}$(printf '%*s' $(( max_ci - 1 )) '')"
    date_padded=$(printf "%-${max_date}s" "$updated_short")
    age_padded=$(printf "%-${max_age}s" "$age_text")

    # Wrap the (already-padded) PR number in an OSC 8 hyperlink targeting the PR
    num_linked=$(hyperlink "$url" "$num_padded")

    # Display row: with OSC 8 hyperlinks
    display_row="${repo_padded}  ${num_color}${num_linked}${RESET}  ${title_color}${title_padded}${RESET}  ${ci_color}${ci_padded}${RESET}  ${DIM}${date_padded}${RESET}  ${age_color}${age_padded}${RESET}"
    # Picker row: same colors but no OSC 8 hyperlinks (gum doesn't render them)
    picker_row="${repo_padded}  ${num_color}${num_padded}${RESET}  ${title_color}${title_padded}${RESET}  ${ci_color}${ci_padded}${RESET}  ${DIM}${date_padded}${RESET}  ${age_color}${age_padded}${RESET}"

    display_rows+=("$display_row")
    picker_rows+=("$picker_row")
    url_list+=("$url")

    # Only print the row in table mode
    if [[ "$MODE" == "table" ]]; then
        printf '%s\n' "$display_row"
    fi
done <<< "$rows"

# --- Compute summary stats ---
draft_count=$(echo "$json" | jq '[.[] | select(.isDraft)] | length')
# Compute stale count in bash (cross-platform date handling) instead of awk shell-out
stale_count=0
while IFS=$'\t' read -r _ _ _ _ updated _ _ _ _; do
    [[ -z "$updated" ]] && continue
    epoch=$(parse_date "$updated" '%s')
    [[ -z "$epoch" ]] && continue
    (( epoch < six_months_ago )) && stale_count=$(( stale_count + 1 ))
done <<< "$rows"

scope_label="all repos"
[[ -n "$OWNER" ]] && scope_label="owner: ${OWNER}"

summary="${BOLD}${count}${RESET} open PR(s) (${scope_label})"
[[ "$draft_count" -gt 0 ]] && summary+=" — ${GRAY}${draft_count} draft*${RESET}"
[[ "$stale_count" -gt 0 ]] && summary+=" — ${RED}${stale_count} stale ⚠${RESET}"

# --- Table mode: print summary and exit ---
if [[ "$MODE" == "table" ]]; then
    echo ""
    printf '%s\n' "$summary"
    exit 0
fi

# --- Picker mode: launch gum filter ---
# Detect platform opener
if command -v xdg-open &>/dev/null; then
    opener="xdg-open"
elif command -v open &>/dev/null; then
    opener="open"
else
    printf '%s\n' "${RED}No URL opener found (xdg-open or open). Use --table.${RESET}" >&2
    exit 1
fi

# Build a map from picker row → URL.
# gum may transform output slightly (e.g. trim trailing spaces or strip
# certain ANSI sequences), so we'll match using a normalized version
# (ANSI codes stripped, leading/trailing whitespace trimmed).
declare -A row_to_url
normalize() {
    # Remove all ANSI escape sequences and OSC 8 hyperlink wrappers,
    # then collapse leading/trailing whitespace.
    local s="$1"
    # Strip CSI sequences: ESC[...m
    s=$(printf '%s' "$s" | sed -E $'s/\x1b\\[[0-9;]*[mK]//g')
    # Strip OSC 8 hyperlink sequences: ESC]8;;...ESC\
    s=$(printf '%s' "$s" | sed -E $'s/\x1b\\]8;;[^\x1b]*\x1b\\\\//g')
    # Trim trailing whitespace
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

for i in "${!picker_rows[@]}"; do
    key=$(normalize "${picker_rows[$i]}")
    row_to_url["$key"]="${url_list[$i]}"
done

# Disable -e/-u/pipefail just for the picker section: gum returns non-zero
# on cancel which is normal, and we don't want the strict mode to abort
# silently before we can react.
set +eu
set +o pipefail

# Pass items as positional arguments. gum displays them as-is and returns
# the chosen line on stdout. The header keeps column titles visible.
#
# gum filter prefixes each item with "<indicator> " (2 chars by default).
# We pad the header lines with the same width so columns line up with the
# rows below.
indent="  "
gum_header="${indent}${plain_header}"$'\n'"${indent}${sep_str}"$'\n'"${indent}${summary}"
selected=$(gum filter \
    --header="$gum_header" \
    --placeholder="Filter PRs (Enter to open, Esc to quit)…" \
    --indicator="▸" \
    --indicator.foreground="216" \
    --match.foreground="222" \
    --prompt="❯ " \
    --prompt.foreground="141" \
    --height=20 \
    --no-fuzzy \
    --no-show-help \
    -- "${picker_rows[@]}")
gum_status=$?

set -eu
set -o pipefail

# Cancelled (Ctrl-C / Esc) or error → exit silently
[[ $gum_status -ne 0 || -z "$selected" ]] && exit 0

# Look up the URL using the normalized form of the selected row
selected_key=$(normalize "$selected")
chosen_url="${row_to_url[$selected_key]:-}"

if [[ -n "$chosen_url" ]]; then
    printf '%s %s\n' "${CYAN}Opening${RESET}" "$chosen_url"
    $opener "$chosen_url" &>/dev/null &
    disown
else
    # Debug info to help diagnose if matching fails
    printf '%s\n' "${RED}Could not match selection to a PR URL.${RESET}" >&2
    printf '  selected (normalized): %q\n' "$selected_key" >&2
    printf '  available keys:\n' >&2
    for k in "${!row_to_url[@]}"; do
        printf '    %q\n' "$k" >&2
    done
    exit 1
fi
